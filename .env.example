# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/polister_development?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Admin Bootstrap (optional; used by `yarn user:create-admin`)
# ADMIN_EMAIL="admin@example.com"
# ADMIN_PASSWORD="change-me"
# ADMIN_NAME="Polister 管理者"

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="your-mapbox-access-token"

# Google Cloud Storage (本番環境のみ)
# GCS_BUCKET_NAME="polister-board-images"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account-key.json"  # 開発環境でGCSを使う場合

# Prisma
PRISMA_GENERATE_DATAPROXY=false
