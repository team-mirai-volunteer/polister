// Polister Database Schema
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// 掲示板
model Board {
  id             String                                @id @default(uuid())
  boardNumber    String?                               @map("board_number")
  name           String?
  address        String
  location       Unsupported("geography(POINT, 4326)")
  municipalityId String                                @map("municipality_id")
  trustLevel     TrustLevel                            @default(LEVEL_3) @map("trust_level")
  status         BoardStatus                           @default(PENDING)
  note           String?                               @db.Text
  createdAt      DateTime                              @default(now()) @map("created_at")
  updatedAt      DateTime                              @updatedAt @map("updated_at")
  deletedAt      DateTime?                             @map("deleted_at")

  municipality  Municipality         @relation(fields: [municipalityId], references: [id])
  images        BoardImage[]
  verifications Verification[]
  histories     BoardHistory[]
  importRows    BoardImportRow[]
  importMissing BoardImportMissing[]

  @@index([location], type: Gist)
  @@index([municipalityId])
  @@index([municipalityId, deletedAt])
  @@index([trustLevel])
  @@index([status])
  @@map("boards")
}

model BoardImportBatch {
  id             String            @id @default(uuid())
  municipalityId String            @map("municipality_id")
  status         BoardImportStatus @default(UPLOADED)
  sourceFileName String            @map("source_file_name")
  storagePath    String            @map("storage_path")
  fileSize       Int               @map("file_size")
  checksum       String
  totalRows      Int               @map("total_rows")
  matchedCount   Int               @map("matched_count")
  newCount       Int               @map("new_count")
  missingCount   Int               @map("missing_count")
  updatedCount   Int               @map("updated_count")
  duplicateCount Int               @map("duplicate_count")
  uploadedBy     String?           @map("uploaded_by")
  uploadedAt     DateTime          @default(now()) @map("uploaded_at")
  confirmedBy    String?           @map("confirmed_by")
  confirmedAt    DateTime?         @map("confirmed_at")
  notes          String?           @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  municipality    Municipality         @relation(fields: [municipalityId], references: [id], onDelete: Restrict)
  uploadedByUser  User?                @relation("BoardImportBatchUploadedBy", fields: [uploadedBy], references: [id], onDelete: Restrict)
  confirmedByUser User?                @relation("BoardImportBatchConfirmedBy", fields: [confirmedBy], references: [id], onDelete: SetNull)
  rows            BoardImportRow[]
  missing         BoardImportMissing[]
  histories       BoardHistory[]

  @@index([municipalityId])
  @@index([status])
  @@index([uploadedAt])
  @@map("board_import_batches")
}

model BoardImportRow {
  id              String                     @id @default(uuid())
  batchId         String                     @map("batch_id")
  prefecture      String
  city            String
  boardNumber     String?                    @map("board_number")
  address         String
  name            String?
  latitude        Decimal                    @db.Decimal(10, 7)
  longitude       Decimal                    @db.Decimal(10, 7)
  note            String?
  rawJson         Json                       @map("raw_json")
  matchedBoardId  String?                    @map("matched_board_id")
  matchConfidence BoardImportMatchConfidence @default(NONE) @map("match_confidence")
  distanceMeter   Float?                     @map("distance_meter")
  diff            Json?                      @map("diff_data")
  suggestedAction BoardImportSuggestedAction @default(KEEP) @map("suggested_action")
  finalDecision   BoardImportRowDecision?    @map("final_decision")
  assigneeId      String?                    @map("assignee_id")
  comment         String?                    @db.Text
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  batch        BoardImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  matchedBoard Board?           @relation(fields: [matchedBoardId], references: [id], onDelete: SetNull)
  assignee     User?            @relation("BoardImportRowAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([matchConfidence])
  @@index([suggestedAction])
  @@index([finalDecision])
  @@map("board_import_rows")
}

model BoardImportMissing {
  id            String                      @id @default(uuid())
  batchId       String                      @map("batch_id")
  boardId       String                      @map("board_id")
  reason        BoardImportMissingReason    @default(NOT_IN_SOURCE)
  finalDecision BoardImportMissingDecision? @map("final_decision")
  comment       String?                     @db.Text
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")

  batch BoardImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  board Board            @relation(fields: [boardId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([boardId])
  @@map("board_import_missing")
}

// 市区町村
model Municipality {
  // 基本属性（国土数値情報から取得）
  id         String                                        @id @default(uuid())
  name       String
  code       String                                        @unique
  prefecture String
  polygon    Unsupported("geography(MULTIPOLYGON, 4326)")?
  source     String                                        @default("MLIT")

  // データ収集管理属性（Polister独自）
  url           String?            @db.Text
  boardCount    Int?               @map("board_count")
  dataVersion   String?            @map("data_version")
  status        MunicipalityStatus @default(NOT_STARTED)
  contactStatus ContactStatus?     @map("contact_status")
  notes         String?            @db.Text
  folderId      String?            @map("folder_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boards        Board[]
  userLocations UserLocation[]
  importBatches BoardImportBatch[]

  @@index([polygon], type: Gist)
  @@index([code])
  @@index([status])
  @@map("municipalities")
}

// ユーザー
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  name              String?
  slackName         String?   @map("slack_name")
  image             String?
  role              UserRole  @default(VIEWER)
  trustScore        Float     @default(0.0) @map("trust_score")
  verificationCount Int       @default(0) @map("verification_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  emailVerified     DateTime? @map("email_verified")

  accounts                Account[]
  sessions                Session[]
  verifications           Verification[]
  boardImages             BoardImage[]
  userLocations           UserLocation[]
  boardHistories          BoardHistory[]
  importBatchesUploaded   BoardImportBatch[] @relation("BoardImportBatchUploadedBy")
  importBatchesConfirmed  BoardImportBatch[] @relation("BoardImportBatchConfirmedBy")
  assignedBoardImportRows BoardImportRow[]   @relation("BoardImportRowAssignee")

  @@index([email])
  @@index([role])
  @@map("users")
}

// NextAuth Account
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session
model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth VerificationToken
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 検証記録
model Verification {
  id          String   @id @default(uuid())
  boardId     String   @map("board_id")
  userId      String   @map("user_id")
  result      Boolean
  hasPhoto    Boolean  @default(false) @map("has_photo")
  gpsAccuracy Float?   @map("gps_accuracy")
  comment     String?  @db.Text
  verifiedAt  DateTime @default(now()) @map("verified_at")
  createdAt   DateTime @default(now()) @map("created_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id])

  @@index([boardId])
  @@index([userId])
  @@map("verifications")
}

// 掲示板画像
model BoardImage {
  id        String    @id @default(uuid())
  boardId   String    @map("board_id")
  userId    String    @map("user_id")
  imageUrl  String    @map("image_url")
  takenAt   DateTime? @map("taken_at")
  createdAt DateTime  @default(now()) @map("created_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([boardId])
  @@map("board_images")
}

// ユーザー居住地
model UserLocation {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  municipalityId String   @map("municipality_id")
  isPrimary      Boolean  @default(false) @map("is_primary")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  municipality Municipality @relation(fields: [municipalityId], references: [id])

  @@index([userId])
  @@index([municipalityId])
  @@map("user_locations")
}

// 掲示板変更履歴
model BoardHistory {
  id            String       @id @default(uuid())
  boardId       String       @map("board_id")
  importBatchId String?      @map("import_batch_id")
  beforeData    Json?        @map("before_data")
  afterData     Json         @map("after_data")
  changeReason  ChangeReason @map("change_reason")
  userId        String?      @map("user_id")
  comment       String?      @db.Text
  changedAt     DateTime     @default(now()) @map("changed_at")

  board       Board             @relation(fields: [boardId], references: [id], onDelete: Restrict)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  importBatch BoardImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([userId])
  @@index([changeReason])
  @@index([changedAt])
  @@index([importBatchId])
  @@map("board_histories")
}

// Enum定義
enum TrustLevel {
  LEVEL_1 // 公式
  LEVEL_2 // 確認済み
  LEVEL_3 // 報告
  LEVEL_4 // 記憶
}

enum BoardStatus {
  PENDING // 未検証
  VERIFIED // 検証済み
  REJECTED // 却下
}

enum UserRole {
  VIEWER // 閲覧者
  EDITOR // 編集者
  COORDINATOR // 地域コーディネーター
  ADMIN // 管理者
}

// 自治体作業ステータス
enum MunicipalityStatus {
  NOT_STARTED // 未着手
  IN_PROGRESS // 作業中
  CONTACTING // 自治体へ問い合わせ中
  DIGITIZING // 紙で入手したのでデジタル化中
  PDF_COMPLETED // PDFを作ったので後はお願い
  CSV_COMPLETED // CSVを作ったので後はお願い
  COMPLETED // 完了(CSV正規化済み)
  QUALITY_CHECK // データの不備を確認・調整中
  URL_FOUND // URL見つけたので後はお願い
  OTHER // その他
  OUT_OF_SCOPE // 対象外地域
}

// 選管対応ステータス
enum ContactStatus {
  NOT_CONTACTED // 未問い合わせ
  WAITING_RESPONSE // 回答待ち
  RECEIVED // データ受領
  DIRECT_TO_CANDIDATE // 候補者へ直接提供
  STOPPED // 問い合わせ停止（北海道、福岡県等）
}

enum BoardImportStatus {
  UPLOADED
  REVIEWING
  APPLIED
  CANCELLED
}

enum BoardImportMatchConfidence {
  HIGH
  MEDIUM
  LOW
  NONE
}

enum BoardImportSuggestedAction {
  KEEP
  UPDATE
  CREATE
  SKIP
}

enum BoardImportRowDecision {
  UPDATE
  CREATE
  IGNORE
}

enum BoardImportMissingReason {
  NOT_IN_SOURCE
  OUT_OF_SCOPE
}

enum BoardImportMissingDecision {
  KEEP
  SOFT_DELETE
  FOLLOW_UP
}

// 変更理由
enum ChangeReason {
  MANUAL_INPUT // 手動入力
  DATA_SOURCE_IMPORT // 自治体データインポート
  FIELD_VERIFICATION // 現地確認による修正
  ERROR_CORRECTION // エラー修正
  DATA_NORMALIZATION // データ正規化
  GEOCODING_UPDATE // ジオコーディング更新
  MIGRATION // データマイグレーション
  SYSTEM_UPDATE // システムによる自動更新
  OTHER // その他
}
