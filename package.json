{
  "name": "polister",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "yarn typecheck && yarn lint && yarn format:check",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "prisma db push --schema=./src/infrastructure/database/schema.prisma",
    "db:studio": "prisma studio --schema=./src/infrastructure/database/schema.prisma",
    "db:generate": "prisma generate --schema=./src/infrastructure/database/schema.prisma",
    "docs:dev": "cd docs && yarn start",
    "docs:build": "cd docs && yarn build",
    "docs:serve": "cd docs && yarn serve"
  },
  "prisma": {
    "schema": "./src/infrastructure/database/schema.prisma"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.2",
    "@mui/material-nextjs": "^7.3.2",
    "@prisma/client": "^6.16.2",
    "mapbox-gl": "^3.15.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "29",
    "@playwright/test": "^1.55.1",
    "@testing-library/dom": "10",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "16",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "jest": "29",
    "jest-environment-jsdom": "^30.1.2",
    "jest-mock-extended": "^4.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prisma": "^6.16.2",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
