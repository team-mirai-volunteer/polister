{
  "name": "polister",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "yarn typecheck && yarn lint && yarn format:check",
    "db:push": "prisma db push --schema=./src/infrastructure/database/schema.prisma",
    "db:studio": "prisma studio --schema=./src/infrastructure/database/schema.prisma",
    "db:generate": "prisma generate --schema=./src/infrastructure/database/schema.prisma",
    "docs:dev": "cd docs && yarn start",
    "docs:build": "cd docs && yarn build",
    "docs:serve": "cd docs && yarn serve"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.2",
    "@mui/material-nextjs": "^7.3.2",
    "@prisma/client": "^6.16.2",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "prettier": "^3.6.2",
    "prisma": "^6.16.2",
    "typescript": "^5"
  }
}
